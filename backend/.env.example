# --- MongoDB Atlas ---
# Atlas dashboard > Database > Connect > Drivers > Python > copy the URI, then swap in your password
# Example shape: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=phish_raksha

# --- External APIs (same as before) ---
VT_API_KEY=your_virustotal_api_key
GEMINI_API_KEY=your_gemini_api_key

# --- Admin Dashboard ---
# Shared password used to log into /admin for this prototype phase
ADMIN_PASSWORD=change_me_before_running
# Random signing key for the session cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=change_me_to_a_random_64_char_hex_string

# --- CORS ---
# Comma-separated list of origins allowed to call /api/*  (your taskpane's origin)
ALLOWED_ORIGINS=https://localhost:3000
